generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum QuantityCertainty {
  exact
  approximate
  unknown
}

enum InventoryStatus {
  main_stock
  partner_inventory
  retail_store
  in_transit
  sold
  returned
  unknown
}

enum ConfidenceState {
  photo_only
  draft_photo
  imported_unverified
  manually_entered
  count_verified
  sales_reconciled
  conflict_detected
}

enum Source {
  photo
  import
  manual_entry
  sales_sync
  erp_import
}

enum InventoryEventType {
  import
  photo_capture
  photo_draft
  manual_entry
  count
  sale
  return
  adjustment
  partner_assign
  verification
  conflict_detection
  conflict_resolution
}

enum ImportJobStatus {
  queued
  processing
  complete
  failed
}

enum UserRole {
  owner
  warehouse
  sales
  finance
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  brandUsers      BrandUser[]
  inventoryEvents InventoryEvent[]

  @@map("users")
}

model Brand {
  id                       String    @id @default(uuid())
  name                     String
  slug                     String    @unique
  confidenceScore          Float?    @map("confidence_score")
  confidenceBreakdown      Json?     @map("confidence_breakdown")
  confidenceLastComputedAt DateTime? @map("confidence_last_computed_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  brandUsers      BrandUser[]
  products        Product[]
  stockLots       StockLot[]
  salesRecords    SalesRecord[]
  importJobs      ImportJob[]
  inventoryEvents InventoryEvent[]

  @@map("brands")
}

model BrandUser {
  brandId String   @map("brand_id")
  userId  String   @map("user_id")
  role    UserRole

  brand Brand @relation(fields: [brandId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([brandId, userId])
  @@map("brand_users")
}

model Product {
  id           String   @id @default(uuid())
  brandId      String   @map("brand_id")
  sku          String?
  name         String?
  category     String?
  color        String?
  size         String?
  images       String[] @default([])
  costPrice    Decimal? @map("cost_price") @db.Decimal(12, 2)
  sellingPrice Decimal? @map("selling_price") @db.Decimal(12, 2)
  tags         String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  brand        Brand         @relation(fields: [brandId], references: [id])
  stockLots    StockLot[]
  salesRecords SalesRecord[]

  @@index([brandId, sku])
  @@index([brandId, category])
  @@map("products")
}

model StockLot {
  id                String            @id @default(uuid())
  brandId           String            @map("brand_id")
  productId         String            @map("product_id")
  quantity          Int?
  quantityCertainty QuantityCertainty @default(unknown) @map("quantity_certainty")
  inventoryStatus   InventoryStatus   @default(main_stock) @map("inventory_status")
  confidenceState   ConfidenceState   @default(photo_only) @map("confidence_state")
  preConflictState  ConfidenceState?  @map("pre_conflict_state")
  source            Source
  photos            String[]          @default([])
  notes             String?
  version           Int               @default(0)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  brand           Brand            @relation(fields: [brandId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  inventoryEvents InventoryEvent[]
  salesRecords    SalesRecord[]

  @@index([brandId, inventoryStatus, confidenceState])
  @@index([brandId, confidenceState])
  @@index([brandId, productId])
  @@map("stock_lots")
}

model InventoryEvent {
  id              String             @id @default(uuid())
  brandId         String             @map("brand_id")
  stockLotId      String             @map("stock_lot_id")
  eventType       InventoryEventType @map("event_type")
  payload         Json               @default("{}")
  createdByUserId String?            @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")

  brand     Brand    @relation(fields: [brandId], references: [id])
  stockLot  StockLot @relation(fields: [stockLotId], references: [id])
  createdBy User?    @relation(fields: [createdByUserId], references: [id])

  @@index([stockLotId, eventType, createdAt])
  @@index([brandId, createdAt(sort: Desc)])
  @@map("inventory_events")
}

model SalesRecord {
  id         String   @id @default(uuid())
  brandId    String   @map("brand_id")
  productId  String   @map("product_id")
  stockLotId String?  @map("stock_lot_id")
  size       String?
  quantity   Int
  price      Decimal? @db.Decimal(12, 2)
  channel    String   @default("direct")
  date       DateTime @db.Date
  partner    String?
  source     String   @default("manual_entry")
  confidence String   @default("medium")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  brand    Brand     @relation(fields: [brandId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  stockLot StockLot? @relation(fields: [stockLotId], references: [id])

  @@index([brandId, productId, date])
  @@index([brandId, date(sort: Desc)])
  @@map("sales_records")
}

model ImportJob {
  id             String          @id @default(uuid())
  brandId        String          @map("brand_id")
  fileUrl        String          @map("file_url")
  status         ImportJobStatus @default(queued)
  rowCount       Int?            @map("row_count")
  processedCount Int             @default(0) @map("processed_count")
  errorRows      Json            @default("[]") @map("error_rows")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id])

  @@map("import_jobs")
}
