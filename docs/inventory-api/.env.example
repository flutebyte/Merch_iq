S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# App URLs (used for OAuth redirect URIs)
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Shopify — create app at partners.shopify.com
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# Amazon SP-API — register at sellercentral.amazon.in
AMAZON_CLIENT_ID=""
AMAZON_CLIENT_SECRET=""
AMAZON_APP_ID=""

# Flipkart Seller API — apply at seller.flipkart.com/api
FLIPKART_CLIENT_ID=""
FLIPKART_CLIENT_SECRET=""

# WhatsApp / Meta — create app at developers.facebook.com
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
