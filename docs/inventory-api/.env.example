DATABASE_URL="postgresql://inventory:inventory_dev_pw@localhost:5432/inventory_db"

JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

PORT=3001
CORS_ORIGIN="http://localhost:3000"

# S3 / Cloudflare R2 (leave blank to use dev-placeholder mode)
